# ─────────────────────────────────────────────
#  SofIA – Environment variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────
# Get from: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DB_SSL=true

# ── Twilio ────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── OpenAI ────────────────────────────────────
# Used for: Whisper STT + GPT-4o LLM
OPENAI_API_KEY=sk-...
# Optional: override the chat model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── ElevenLabs TTS ────────────────────────────
# Used ONLY for text-to-speech; NOT as an agent intermediary
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voice ID – find at https://api.elevenlabs.io/v1/voices
# Default: Rachel (21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional: TTS model (default: eleven_turbo_v2 – lowest latency)
ELEVENLABS_MODEL_ID=eleven_turbo_v2
# Optional: voice stability 0.0–1.0 (default 0.5)
ELEVENLABS_STABILITY=0.5
# Optional: similarity boost 0.0–1.0 (default 0.75)
ELEVENLABS_SIMILARITY_BOOST=0.75

# ── Public base URL ───────────────────────────
# Required so Twilio can reach TwiML and WebSocket endpoints.
# In dev use your ngrok HTTPS URL (e.g. https://abc123.ngrok-free.app)
# In prod use your deployed server URL.
BASE_URL=https://your-server.example.com

# ── Legacy ElevenLabs agent (no longer needed) ─
# Kept here for reference / backward compatibility only
# ELEVENLABS_AGENT_ID=your_agent_id
# ELEVENLABS_PHONE_NUMBER_ID=your_phone_number_id
# ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/convai/twilio/outbound-call
# ELEVENLABS_MOCK=false

# ── Call control ──────────────────────────────
# Max simultaneous Twilio outbound calls
MAX_CONCURRENT_CALLS=4

# Worker tick interval in seconds
QUEUE_WORKER_INTERVAL_SECONDS=10

# EN_CURSO calls older than N minutes are auto-resolved as NO_CONTESTA
STALE_CALL_MINUTES=30

# How often (minutes) the worker backfills missing queue items
BACKFILL_INTERVAL_MINUTES=5

# ── Queue fill schedule (Colombia time, UTC-5) ─
# Cron jobs fill the queue at the start of each franja.
# On restart, the app also fills any franja that is missing items today.
CRON_FILL_MANANA=0 7 * * *
CRON_FILL_TARDE=0 14 * * *
CRON_FILL_NOCHE=0 19 * * *

# ── WhatsApp fallback chatbot ─────────────────
# External webhook URL that receives candidate data after 9 failed call attempts
CHATBOT_WEBHOOK_URL=https://your-chatbot-partner.example.com/webhook/initiate

# ── HTTP server ───────────────────────────────
PORT=3000

# ── Timezone ──────────────────────────────────
TZ=America/Bogota
