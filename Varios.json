        "jsonBody": "={\n  \"agent_id\": \"agent_4501khbynht9ennvk32madk7k1jj\",\n  \"agent_phone_number_id\": \"phnum_8101khntfkmbeq6amer4dt70p5vs\",\n  \"to_number\": \"{{ $json.telefono }}\",\n  \"conversation_initiation_client_data\": {\n    \"dynamic_variables\": {\n      \"id\": \"{{ $json.candidato_id }}\",\n      \"nombre\": \"{{ $json.nombre }}\",\n      \"motivo\": \"{{ $json.motivo }}\",\n      \"lista_horarios\": \"{{ $json.lista_horarios }}\",\n      \"eventos_disponibles\": \"{{ $json.eventos_disponibles }}\"\n    }\n  }\n}",
