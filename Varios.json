    {
      "parameters": {
        "jsCode": "const httpResponse = items[0].json;\nconst candidato = $('Procesar_Usuarios').item.json;\n\n// Aquí ponemos directamente el id de 'EN_CURSO'.\n// Más adelante, si quieres, creamos un nodo Supabase que lo lea dinámicamente.\nconst resultadoEnCursoId = 1; // asegúrate que 1 sea el id de EN_CURSO\n\nreturn [{\n  json: {\n    candidato_id: candidato.id,\n    fecha_hora_llamada: new Date().toISOString(),\n    resultado_id: resultadoEnCursoId,\n    conversation_id: httpResponse.conversation_id || null,\n    resumen: \"Llamada iniciada\"\n  }\n}];\n"
