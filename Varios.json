      ],
      "id": "7cf34662-4418-4395-b989-ceb6a767957d",
      "name": "Aggregate"
    },
    {
      "parameters": {
        "jsCode": "const input = items[0].json;\nconst eventos = input.eventos || [];\n\n// Generar textos para el bot\nconst fechasTexto = eventos\n  .map((e, index) => `opción ${index + 1}: ${e.fecha_legible}`)\n  .join(', ');\n\nconst eventosTexto = eventos\n  .map(e => `${e.fecha_legible} (ID: ${e.id})`)\n  .join('; ');\n\n// Obtener datos del candidato desde Split in Batches\nconst candidato = $('Procesar cada candidato').item.json;\n\nreturn [{\n  json: {\n    candidato_id: candidato.id,\n    telefono: candidato.telefono,\n    nombre: `${candidato.nombre} ${candidato.apellido}`,\n    motivo: candidato.fase_actual,\n    lista_horarios: fechasTexto,\n    eventos_disponibles: eventosTexto\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
