# ─────────────────────────────────────────────
#  SofIA – Environment variables
# ─────────────────────────────────────────────

# ── Supabase / PostgreSQL ─────────────────────
#
# Usamos `pg` (driver nativo de PostgreSQL) conectándonos directamente
# al PostgreSQL que corre detrás de Supabase.
#
# Formato recomendado para Supabase (conexión directa, puerto 5432):
#   postgresql://postgres:[TU_PASSWORD]@db.tklnqbdxdcwlgcamnima.supabase.co:5432/postgres
#
# Lo encuentras en: Supabase Dashboard → Settings → Database → Connection string → URI
#
DATABASE_URL=postgresql://postgres:[TU_PASSWORD]@db.tklnqbdxdcwlgcamnima.supabase.co:5432/postgres

# Si prefieres variables separadas (se usan solo si DATABASE_URL está vacío):
DB_HOST=db.tklnqbdxdcwlgcamnima.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
# SSL siempre debe ser true en Supabase
DB_SSL=true

# ── ElevenLabs ────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=agent_4501khbynht9ennvk32madk7k1jj
ELEVENLABS_PHONE_NUMBER_ID=phnum_8101khntfkmbeq6amer4dt70p5vs
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/convai/twilio/outbound-call
# ── Testing ───────────────────────────────────
# true = salta la llamada real a ElevenLabs, genera un conversation_id falso
# false o eliminada = usa ElevenLabs real
ELEVENLABS_MOCK=true

# ── Call control ─────────────────────────────
# Maximum simultaneous outbound calls
MAX_CONCURRENT_CALLS=4

# Interval in seconds for the queue worker
QUEUE_WORKER_INTERVAL_SECONDS=10

# ── Queue fill schedule (node-cron syntax, Colombia time UTC-5) ──
# Default: 07:00, 14:00, 19:00
CRON_FILL_MANANA=0 7 * * *
CRON_FILL_TARDE=0 14 * * *
CRON_FILL_NOCHE=0 19 * * *

# ── HTTP server ───────────────────────────────
PORT=3000

# ── Timezone ─────────────────────────────────
# Colombia Standard Time (no DST)
TZ=America/Bogota

