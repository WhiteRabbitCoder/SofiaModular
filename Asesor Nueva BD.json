    {
      "parameters": {
        "content": "Ventana global: de 08:00 a 20:00 hora local.\n\nhorario_id:\n\nAM: se llama solo si hora actual está entre 08:00 y 13:00.\n\nPM: solo si está entre 14:00 y 20:00.\n\nAMPM: cualquier hora dentro de la ventana global.",
        "height": 272
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1088,
        -272
      ],
      "id": "432bdfb5-261c-4c34-82d4-e0e728a138ce",
      "name": "Sticky Note2"
    },
    {
      "parameters": {
        "jsCode": "// 1. Hora actual del servidor en UTC\nconst nowUtc = new Date();\nlet hora = nowUtc.getUTCHours(); // 0-23\nconst min = nowUtc.getUTCMinutes();\n\n// Ajustar a Colombia (UTC-5)\nhora = (hora - 5 + 24) % 24; // normaliza a 0–23\n\n// Ventana global 6:00 - 22:00\nconst dentroVentanaGlobal = hora >= 6 && hora < 22;\nif (!dentroVentanaGlobal) {\n  // Fuera de ventana global → no llamar\n  return [];\n}\n\n// 2. Intentar leer horario del candidato\nconst horarioItems = $items('Obtener horario', 0, 0);\nlet codigoHorario = null;\n\nif (horarioItems && horarioItems.json && horarioItems.json.codigo) {\n  codigoHorario = horarioItems.json.codigo; // 'AM', 'PM', 'AMPM'\n}\n\n// 3. Validar según franja\nlet permitido = false;\n\nif (!codigoHorario) {\n  // Si no hay horario, usamos solo la ventana global\n  permitido = true;\n} else if (codigoHorario === 'AM') {\n  permitido = hora >= 6 && hora < 13;\n} else if (codigoHorario === 'PM') {\n  permitido = hora >= 14 && hora < 22;\n} else if (codigoHorario === 'AMPM') {\n  permitido = hora >= 6 && hora < 22;\n}\n\nif (!permitido) {\n  return [];\n}\n\n// Debug opcional\nitems[0].json.debug_hora_local = hora;\nitems[0].json.debug_min_local = min;\nitems[0].json.debug_horario_codigo = codigoHorario || 'SIN_HORARIO';\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
