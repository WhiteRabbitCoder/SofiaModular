      "parameters": {
        "jsCode": "const dias = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];\nconst meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];\n\nreturn items.map(item => {\n  // Tomamos la hora directamente del string sin conversión de zona horaria\n  const fechaStr = item.json.fecha_hora.replace('+00:00', '');\n  const fecha = new Date(fechaStr);\n  \n  const dia = dias[fecha.getDay()];\n  const numeroDia = fecha.getDate();\n  const mes = meses[fecha.getMonth()];\n  const horas = fecha.getHours();\n  const minutos = fecha.getMinutes().toString().padStart(2, '0');\n  const ampm = horas >= 12 ? 'PM' : 'AM';\n  const hora12 = horas % 12 || 12;\n  \n  return {\n    json: {\n      ...item.json,\n      fecha_legible: `${dia} ${numeroDia} de ${mes} a las ${hora12}:${minutos} ${ampm}`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        368
      ],
      "id": "83ece6bc-7ff8-4030-840e-19d62d916a13",
      "name": "Parseo de fecha"
