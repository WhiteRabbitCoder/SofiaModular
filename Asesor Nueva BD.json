    {
      "parameters": {
        "jsCode": "// Candidatos que llegan del nodo \"Condición de usuarios pendientes\"\nconst candidatos = $items('Condición de usuarios pendientes', 0); // todos los items\n\n// Registros candidato_ideal desde \"Obtener CI candidatos\"\nconst ciItems = $items('Obtener CI candidatos', 0);\nconst ciMap = {};\nfor (const ciItem of ciItems) {\n  const ci = ciItem.json;\n  ciMap[ci.candidato_id] = ci;\n}\n\n// Mapear, añadir campos de prioridad y ordenar\nconst enriquecidos = candidatos.map((candItem) => {\n  const c = candItem.json;\n  const ci = ciMap[c.id] || null;\n\n  const ciTotal = ci ? ci.ci_total || 0 : 0;\n  const intentos = c.intentos_llamada || 0;\n  const ultimo = c.ultimo_contacto ? new Date(c.ultimo_contacto).getTime() : null;\n\n  return {\n    json: {\n      ...c,\n      ci_total: ciTotal,\n      intentos_llamada: intentos,\n      ultimo_contacto_ts: ultimo\n    }\n  };\n});\n\n// Ordenar: mayor ci_total, menor intentos, ultimo_contacto más antiguo\nenriquecidos.sort((a, b) => {\n  const ca = a.json;\n  const cb = b.json;\n\n  // 1) ci_total desc\n  if (cb.ci_total !== ca.ci_total) {\n    return cb.ci_total - ca.ci_total;\n  }\n\n  // 2) intentos_llamada asc\n  if (ca.intentos_llamada !== cb.intentos_llamada) {\n    return ca.intentos_llamada - cb.intentos_llamada;\n  }\n\n  // 3) ultimo_contacto más antiguo primero (null al final)\n  const ua = ca.ultimo_contacto_ts;\n  const ub = cb.ultimo_contacto_ts;\n\n  if (ua === null && ub === null) return 0;\n  if (ua === null) return 1;   // null al final\n  if (ub === null) return -1;\n\n  return ua - ub;\n});\n\n// Devolver los candidatos ya ordenados como items para el siguiente nodo\nreturn enriquecidos;\n"
      },
      "type": "n8n-nodes-base.code",
